# Peapod
PEAPOD_APP_ENV=production
PEAPOD_LOG_LEVEL=info
PEAPOD_ACCESS_LOG_MODE=attention
PEAPOD_ACCESS_LOG_SLOW_THRESHOLD_SECONDS=3
PEAPOD_ADDR=:8095
PEAPOD_BIND=127.0.0.1
PEAPOD_PORT=8095
PEAPOD_PUBLIC_URL=http://127.0.0.1:8095
PEAPOD_SESSION_SECRET=replace-with-random-secret
PEAPOD_PASSWORD=legacy-emergency-password
PEAPOD_DB_NAME=peapod
PEAPOD_DB_USER=peapod
PEAPOD_DB_PASSWORD=replace-with-db-password
PEAPOD_DB_ROOT_PASSWORD=replace-with-db-root-password
PEAPOD_DB_DSN=peapod:replace-with-db-password@tcp(mysql:3306)/peapod?parseTime=true&charset=utf8mb4&loc=Local
PEAPOD_BOOTSTRAP_USERNAME=admin
PEAPOD_BOOTSTRAP_PASSWORD=change-me-at-first-login
PEAPOD_BOOTSTRAP_DISPLAY_NAME=管理员
PEAPOD_BOOTSTRAP_EMAIL=
PEAPOD_AUDIT_PATH=/data/audit.jsonl
PEAPOD_TASKS_PATH=/data/tasks.json
PEAPOD_FRONTEND_DIR=/app/frontend/dist
PEAPOD_MYSQL_BIND=127.0.0.1
PEAPOD_MYSQL_PORT=13307
PEAPOD_MYSQL_IMAGE=mysql:8.4

# Extra external links in Peapod Settings -> 基础设施入口.
# Either JSON map: {"registry":"https://registry.example.com"}
# Or array: [{"id":"registry","title":"镜像仓库","url":"https://registry.example.com","description":"查看镜像和 tag"}]
PEAPOD_LINKS_JSON=

# Woodpecker
WOODPECKER_SERVER=http://woodpecker-server:8000
WOODPECKER_PUBLIC_URL=http://127.0.0.1:8000
WOODPECKER_TOKEN=replace-with-woodpecker-api-token
WOODPECKER_HOST=http://127.0.0.1:8000
WOODPECKER_SERVER_IMAGE=woodpeckerci/woodpecker-server:v3
WOODPECKER_AGENT_IMAGE=woodpeckerci/woodpecker-agent:v3
WOODPECKER_ADMIN=
WOODPECKER_AGENT_SECRET=replace-with-agent-secret
WOODPECKER_GITHUB=false
WOODPECKER_GITHUB_CLIENT=
WOODPECKER_GITHUB_SECRET=
WOODPECKER_MAX_WORKFLOWS=1

# Beszel
BESZEL_APP_URL=http://127.0.0.1:8090
BESZEL_USER_EMAIL=
BESZEL_USER_PASSWORD=
PEAPOD_BESZEL_BASE_URL=http://beszel:8090
PEAPOD_BESZEL_PUBLIC_URL=http://127.0.0.1:8090
PEAPOD_BESZEL_EMAIL=
PEAPOD_BESZEL_PASSWORD=

# Lightweight logs
DOZZLE_IMAGE=amir20/dozzle:latest
DOZZLE_BIND=127.0.0.1
DOZZLE_PORT=8081
DOZZLE_PUBLIC_URL=http://127.0.0.1:8081
PEAPOD_DOZZLE_BASE_URL=http://dozzle:8080
PEAPOD_DOZZLE_PUBLIC_URL=http://127.0.0.1:8081
DOZZLE_AUTH_PROVIDER=none
DOZZLE_AUTH_TTL=48h
PEAPOD_DOZZLE_USERNAME=
PEAPOD_DOZZLE_PASSWORD=
DOZZLE_ENABLE_MCP=true
DOZZLE_ENABLE_ACTIONS=false
DOZZLE_ENABLE_SHELL=false

# Grafana stack
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_PUBLIC_URL=http://127.0.0.1:3000
PEAPOD_GRAFANA_PUBLIC_URL=
PROMETHEUS_RETENTION=15d
LOKI_RETENTION_DAYS=7
TEMPO_RETENTION=72h

# Monitoring
PEAPOD_MONITOR_SSH_KEY_PATH=/data/ssh/monitor_ed25519
PEAPOD_MONITOR_REFRESH_SECONDS=20
PEAPOD_MONITOR_WARN_DISK=80
PEAPOD_MONITOR_CRIT_DISK=90
PEAPOD_MONITOR_WARN_MEMORY=80
PEAPOD_MONITOR_HOSTS_JSON=[{"id":"local","name":"本机","role":"infra","beszel_names":["local","localhost","本机","peapod"],"containers":["peapod","woodpecker-server","woodpecker-agent","beszel","dozzle","grafana","loki","prometheus","tempo"]}]
