# Zephyr
ZEPHYR_ADDR=:8095
ZEPHYR_BIND=127.0.0.1
ZEPHYR_PORT=8095
ZEPHYR_PUBLIC_URL=http://127.0.0.1:8095
ZEPHYR_SESSION_SECRET=replace-with-random-secret
ZEPHYR_PASSWORD=legacy-emergency-password
ZEPHYR_DB_NAME=zephyr
ZEPHYR_DB_USER=zephyr
ZEPHYR_DB_PASSWORD=replace-with-db-password
ZEPHYR_DB_ROOT_PASSWORD=replace-with-db-root-password
ZEPHYR_DB_DSN=zephyr:replace-with-db-password@tcp(zephyr-mysql:3306)/zephyr?parseTime=true&charset=utf8mb4&loc=Local
ZEPHYR_BOOTSTRAP_USERNAME=admin
ZEPHYR_BOOTSTRAP_PASSWORD=change-me-at-first-login
ZEPHYR_BOOTSTRAP_DISPLAY_NAME=管理员
ZEPHYR_BOOTSTRAP_EMAIL=
ZEPHYR_AUDIT_PATH=/data/audit.jsonl
ZEPHYR_TASKS_PATH=/data/tasks.json
ZEPHYR_FRONTEND_DIR=frontend/dist
ZEPHYR_MYSQL_BIND=127.0.0.1
ZEPHYR_MYSQL_PORT=13307
ZEPHYR_MYSQL_IMAGE=mysql:8.4

# Extra external links in Zephyr Settings -> 基础设施入口.
# Either JSON map: {"registry":"https://registry.example.com"}
# Or array: [{"id":"registry","title":"镜像仓库","url":"https://registry.example.com","description":"查看镜像和 tag"}]
ZEPHYR_LINKS_JSON=

# Woodpecker
WOODPECKER_SERVER=http://woodpecker-server:8000
WOODPECKER_PUBLIC_URL=http://127.0.0.1:8000
WOODPECKER_TOKEN=replace-with-woodpecker-api-token
WOODPECKER_HOST=http://127.0.0.1:8000
WOODPECKER_SERVER_IMAGE=woodpeckerci/woodpecker-server:v3
WOODPECKER_AGENT_IMAGE=woodpeckerci/woodpecker-agent:v3
WOODPECKER_ADMIN=
WOODPECKER_AGENT_SECRET=replace-with-agent-secret
WOODPECKER_GITHUB=false
WOODPECKER_GITHUB_CLIENT=
WOODPECKER_GITHUB_SECRET=
WOODPECKER_MAX_WORKFLOWS=1

# Beszel
BESZEL_APP_URL=http://127.0.0.1:8090
BESZEL_USER_EMAIL=
BESZEL_USER_PASSWORD=
ZEPHYR_BESZEL_BASE_URL=http://beszel:8090
ZEPHYR_BESZEL_PUBLIC_URL=http://127.0.0.1:8090
ZEPHYR_BESZEL_EMAIL=
ZEPHYR_BESZEL_PASSWORD=

# Lightweight logs
DOZZLE_IMAGE=amir20/dozzle:latest
DOZZLE_BIND=127.0.0.1
DOZZLE_PORT=8081
DOZZLE_PUBLIC_URL=http://127.0.0.1:8081
ZEPHYR_DOZZLE_PUBLIC_URL=http://127.0.0.1:8081
DOZZLE_ENABLE_ACTIONS=false
DOZZLE_ENABLE_SHELL=false

# Grafana stack
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_PUBLIC_URL=http://127.0.0.1:3000
ZEPHYR_GRAFANA_PUBLIC_URL=
PROMETHEUS_RETENTION=15d
LOKI_RETENTION_DAYS=7
TEMPO_RETENTION=72h

# Monitoring
ZEPHYR_MONITOR_SSH_KEY_PATH=/data/ssh/monitor_ed25519
ZEPHYR_MONITOR_REFRESH_SECONDS=20
ZEPHYR_MONITOR_WARN_DISK=80
ZEPHYR_MONITOR_CRIT_DISK=90
ZEPHYR_MONITOR_WARN_MEMORY=80
ZEPHYR_MONITOR_HOSTS_JSON=[{"id":"local","name":"本机","role":"infra","beszel_names":["local","localhost","本机","zephyr"],"containers":["zephyr","woodpecker-server","woodpecker-agent","beszel","dozzle","grafana","loki","prometheus","tempo"]}]
